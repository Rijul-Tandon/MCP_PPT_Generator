# Optional. Set to groq or gemini to force a provider.
LLM_PROVIDER=groq

# Groq is preferred automatically when GROQ_API_KEY is present.
GROQ_API_KEY=replace-with-your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini remains supported as a fallback or alternative provider.
GEMINI_API_KEY=replace-with-your-gemini-key
GEMINI_MODEL=gemini-2.0-flash
